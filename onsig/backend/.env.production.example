# =============================================================================
# OnSig backend — PRODUCTION env vars
# =============================================================================
# This file is a TEMPLATE. In production every value is pushed to Fly.io's
# encrypted secret store with `flyctl secrets set` — never commit real values.
#
# Push a secret:
#   flyctl secrets set KEY=value --app onsig-prod
#
# List secret keys (values stay hidden):
#   flyctl secrets list --app onsig-prod
#
# Local override for `npm run start`-style dry runs:
#   cp .env.production.example .env.production.local
# =============================================================================

# ─── Runtime (non-secret, also lives in fly.toml [env]) ──────────────────────
NODE_ENV=production
PORT=3001
LOG_LEVEL=info

# ─── Public origin (non-secret) ──────────────────────────────────────────────
# Canonical URL the app advertises itself as. Used for absolute links in
# email, e-signature share links, PDF metadata, OAuth callbacks.
NEXT_PUBLIC_APP_URL=https://onsig-prod.fly.dev
NEXT_PUBLIC_MARKETING_URL=https://onsig-prod.fly.dev
# Flip to "true" only after the marketing site is final + SEO ready.
NEXT_PUBLIC_SEO_INDEXABLE=false

# ─── Database (Neon Postgres) ────────────────────────────────────────────────
# Pooled connection — used by the request-path runtime.
POSTGRES_URL=postgresql://USER:PASS@HOST-pooler.eu-central-1.aws.neon.tech/onsig?sslmode=require
# Direct connection — used by `npm run db:migrate` in fly.toml release_command.
POSTGRES_URL_NON_POOLING=postgresql://USER:PASS@HOST.eu-central-1.aws.neon.tech/onsig?sslmode=require

# ─── JWT / auth ──────────────────────────────────────────────────────────────
# 32+ byte random base64. Generate:  openssl rand -base64 48
JWT_SECRET=__REPLACE_ME__
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d

# ─── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxx
MAIL_FROM="OnSig <noreply@onsig.dev>"

# ─── SMS provider (optional, set when going live with phone OTP) ─────────────
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM=+90...

# ─── Storage (signed PDFs + audit zip) ───────────────────────────────────────
# Options:
#   1. Tigris (Fly's S3-compatible, default recommended for Fly hosts):
#        S3_ENDPOINT=https://fly.storage.tigris.dev
#        S3_REGION=auto
#        S3_BUCKET=onsig-documents
#        S3_ACCESS_KEY_ID=tigris_...
#        S3_SECRET_ACCESS_KEY=tigris_...
#   2. AWS S3 / Cloudflare R2 — same shape, different endpoint
#   3. Azure Blob — keep using the connection string below if you already have
#      a storage account (works on Fly too).
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=onsig-documents

# ─── Observability (optional) ────────────────────────────────────────────────
# If unset, the app falls back to local JSON logs only (visible via flyctl logs).
# Wire one of:
#   - APPLICATIONINSIGHTS_CONNECTION_STRING  (Azure App Insights, even from Fly)
#   - SENTRY_DSN                              (if you switch to Sentry later)
APPLICATIONINSIGHTS_CONNECTION_STRING=

# ─── Feature flags ───────────────────────────────────────────────────────────
FEATURE_TSA_TIMESTAMPING=false       # turn on when TSA provider is configured
FEATURE_PUBLIC_REGISTRATION=true     # set false to gate signups to invites only
