# OnSig Backend — environment template
# Copy to `.env.local` and fill in values for local development.

# --- Database ---------------------------------------------------------------
POSTGRES_URL=postgres://user:password@localhost:5432/onsig

# --- Auth -------------------------------------------------------------------
# Run: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=replace-me-with-48-byte-base64url-string
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800

# --- Mail (Resend) ----------------------------------------------------------
RESEND_API_KEY=
MAIL_FROM_NAME=OnSig
MAIL_FROM_ADDRESS=no-reply@onsig.candarliuzmangm.com.tr

# --- SMS / OTP (Netgsm) -----------------------------------------------------
NETGSM_USER=
NETGSM_PASS=
NETGSM_HEADER=OnSig

# --- Public URL -------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://onsig.candarliuzmangm.com.tr

# --- Default tenant (MVP single-tenant mode) -------------------------------
DEFAULT_TENANT_NAME=Çandarlı Uzman GM
DEFAULT_TENANT_COMPETENT_COURT=İZMİR
DEFAULT_TENANT_BROKERAGE_LICENSE=
